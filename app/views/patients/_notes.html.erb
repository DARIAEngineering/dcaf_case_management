<div id="notes_content">
  <h2><%= t('patient.notes.title') %></h2>

  <%# this has a confusing doc structure; the shared flag checkbox needs to be same row as submit btn. %>
  <%= bootstrap_form_with model: [patient, note],
                          html: { id: 'notes-form' },
                          local: false do |f| %>
    <div class="mb-2">
      <select id="note-template-selector" class="form-select form-select-sm"
              data-note-template-target="true">
        <option value=""><%= t('patient.notes.insert_template', default: 'Insert template...') %></option>
        <% NoteTemplate.available_to(current_user).each do |tmpl| %>
          <option value="<%= tmpl.full_text %>">
            <%= tmpl.name %><%= tmpl.user_id.nil? ? ' (Fund)' : ' (Personal)' %>
          </option>
        <% end %>
      </select>
    </div>
    <script nonce="<%= content_security_policy_nonce %>">
      document.addEventListener('DOMContentLoaded', function() {
        var selector = document.getElementById('note-template-selector');
        if (selector) {
          selector.addEventListener('change', function() {
            if (this.value) {
              document.getElementById('note_full_text').value = this.value;
              this.selectedIndex = 0;
            }
          });
        }
      });
    </script>
    <%= f.text_area :full_text,
                    size: '20x5',
                    placeholder: t('patient.notes.placeholder'),
                    hide_label: true,
                    class: 'col' %>

    <div class="row">
      <div class="col info-form-left">
        <%= f.submit t('patient.notes.submit'), class: "btn btn-primary" %>
      </div>
    
  <% end %>

      <%= bootstrap_form_with model: patient,
                              html: { id: 'shared-flag-form', class: 'text-right text-danger edit_patient' },
                              local: false do |f| %>
        <div class="col">
          <%= f.form_group :shared_flag do %>
            <%= f.check_box :shared_flag, label: t('patient.notes.shared_flag') %>
          <% end %>
        </div>
      <% end %>
    </div>

  <div id="notes-log-patient">
    <%= render partial: 'notes/notes_table',
              locals: { notes: patient.notes.order(created_at: :desc) } %>
  </div>
</div>
